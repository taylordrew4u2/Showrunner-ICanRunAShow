{
  "name": "showrunner",
  "version": "1.0.1",
  "main": "electron/main.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios": "npx -y eas-cli@12.4.1 build --platform ios --profile production",
    "download:ios": "npx -y eas-cli@12.4.1 build --platform ios --profile preview",
    "build:ios:submit": "npx -y eas-cli@12.4.1 build --platform ios --profile production --auto-submit",
    "submit:ios": "npx -y eas-cli@12.4.1 submit --platform ios --latest",
    "build:android": "npx -y eas-cli@12.4.1 build --platform android --profile production",
    "build:android:preview": "npx -y eas-cli@12.4.1 build --platform android --profile preview",
    "download:android": "npx -y eas-cli@12.4.1 build --platform android --profile preview",
    "download:app": "npm run download:android",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "lint": "eslint .",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "mac": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "expo": "^52.0.0",
    "expo-router": "^4.0.0",
    "expo-status-bar": "^1.12.1",
    "expo-print": "^13.0.0",
    "expo-sharing": "^14.0.0",
    "expo-image-picker": "^15.0.0",
    "expo-document-picker": "^11.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.76.2",
    "@react-native-async-storage/async-storage": "^1.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "typescript": "~5.3.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vite": "^6.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "vite-plugin-pwa": "^0.21.1",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.showrunner.app",
    "productName": "Showrunner",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg" },
        { "target": "dir" }
      ]
    }
  }
}
