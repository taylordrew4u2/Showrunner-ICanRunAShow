{
  "name": "showrunner",
  "version": "1.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios": "npx -y eas-cli@12.4.1 build --platform ios --profile production",
    "download:ios": "npx -y eas-cli@12.4.1 build --platform ios --profile preview",
    "build:ios:submit": "npx -y eas-cli@12.4.1 build --platform ios --profile production --auto-submit",
    "submit:ios": "npx -y eas-cli@12.4.1 submit --platform ios --latest",
    "build:android": "npx -y eas-cli@12.4.1 build --platform android --profile production",
    "build:android:preview": "npx -y eas-cli@12.4.1 build --platform android --profile preview",
    "download:android": "npx -y eas-cli@12.4.1 build --platform android --profile preview",
    "download:app": "npm run download:android",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "lint": "eslint .",
    "dev": "vite",
    "build": "vite build",
    "mac": "concurrently -k -s first -n \"web,electron\" \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron desktop/main.js\"",
    "build:mac": "vite build --base ./ && electron-builder --mac"
  },
  "dependencies": {
    "expo": "^54.0.33",
    "expo-router": "^4.0.0",
    "expo-status-bar": "^1.12.1",
    "expo-print": "^13.0.0",
    "expo-sharing": "^14.0.0",
    "expo-image-picker": "^15.0.0",
    "expo-document-picker": "^11.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.76.2",
    "@react-native-async-storage/async-storage": "^1.23.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@types/node": "^24.0.0",
    "typescript": "~5.3.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vite": "^7.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "vite-plugin-pwa": "^1.2.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}
