# AI Configuration (Web App)
# Used by src/utils/aiExtractor.ts for AI-powered schedule parsing
VITE_OPENAI_API_KEY=your-ai-api-key-here

# Turso Database Configuration (Web App)
# Get these values from your Turso dashboard at https://turso.tech
VITE_TURSO_DATABASE_URL=libsql://your-database-name.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token-here

# Turso Database Configuration (Mobile App)
# Same values but with EXPO_PUBLIC_ prefix for Expo
EXPO_PUBLIC_TURSO_DATABASE_URL=libsql://your-database-name.turso.io
EXPO_PUBLIC_TURSO_AUTH_TOKEN=your-auth-token-here
