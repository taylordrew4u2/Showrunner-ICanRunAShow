# ── Server-side env vars (NO VITE_ prefix — never shipped to the browser) ──
# Required — Turso libSQL database. Used by the /api routes via Prisma.
# These are read by the server only; the browser talks to the API, not the DB.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Server-side — used by /api/notify-artist to send "you're up" emails via Brevo.
# Free tier at https://www.brevo.com — 300 emails/day, no domain verification.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Showrunner

# ── Client build-time env vars (Vite reads VITE_*; these DO ship in the bundle) ──
# Optional — enables OpenAI-powered schedule import.
# Without it, the AI import falls back to OCR + a local regex parser.
VITE_OPENAI_API_KEY=
