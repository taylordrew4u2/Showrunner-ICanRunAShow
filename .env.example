# Build-time env vars (Vite reads VITE_*)
# Required — Turso libSQL database for show storage.
VITE_TURSO_DATABASE_URL=libsql://your-database.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token

# Optional — enables OpenAI-powered schedule import.
# Without it, the AI import falls back to OCR + a local regex parser.
VITE_OPENAI_API_KEY=

# Server-side env vars for Vercel serverless functions (no VITE_ prefix).
# Used by /api/notify-artist to send "you're up" emails via Brevo.
# Free tier at https://www.brevo.com — 300 emails/day, no domain verification.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Showrunner
