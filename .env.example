# ── Server-side env vars (NO VITE_ prefix — never shipped to the browser) ──
# Required — Turso libSQL database. Used by the /api routes via @libsql/client.
# These are read by the server only; the browser talks to the API, not the DB.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Server-side — used by /api/notify-artist to send "you're up" emails via Brevo.
# Free tier at https://www.brevo.com — 300 emails/day, no domain verification.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=I Can Run A Show

# Server-side (NO VITE_ prefix) — enables OpenAI-powered schedule import via the
# /api/ai-extract proxy. The key stays on the server and never ships in the
# bundle. Without it, AI import falls back to on-device OCR + a local regex parser.
OPENAI_API_KEY=
